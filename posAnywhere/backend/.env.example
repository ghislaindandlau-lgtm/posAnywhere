# ---------------------------------------------------------------------------
# Example environment configuration for the posAnywhere.io backend.
# Copy this file to ".env" and adjust the values for your environment:
#     cp .env.example .env        (macOS/Linux)
#     copy .env.example .env      (Windows)
# All variables are read by app/config.py via pydantic-settings.
# ---------------------------------------------------------------------------

# Human-friendly application name (shown in API metadata).
APP_NAME=posAnywhere.io

# Database connection string. PostgreSQL is REQUIRED at runtime.
# Local default (matches docker-compose.yml):
DATABASE_URL=postgresql+psycopg2://posanywhere:posanywhere@localhost:5432/posanywhere
# Managed / production example:
#   DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname

# Comma-separated list of browser origins allowed to call the API (CORS).
# Use "*" to allow all during local development.
CORS_ORIGINS=*

# Secret used to sign authentication JWTs. MUST be a long random value in
# production, e.g. generate one with:  openssl rand -hex 32
SECRET_KEY=dev-insecure-change-me-please-set-SECRET_KEY
# Minutes a login token stays valid (default 24h).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Average courier speed (km/h) used by the ETA calculator in the dispatch engine.
AVERAGE_DRIVER_SPEED_KMH=25

# Default kitchen preparation time (minutes) added to every ETA estimate.
DEFAULT_PREP_MINUTES=15

# Logging verbosity: DEBUG, INFO, WARNING, ERROR or CRITICAL.
LOG_LEVEL=INFO
# Log output format: "text" (human-readable) or "json" (for log aggregators
# like Datadog/Loki/CloudWatch). JSON lines include request_id + user fields.
LOG_FORMAT=text
# Optional path to also write a rotating log file (empty = stdout only).
# LOG_FILE=logs/app.log
